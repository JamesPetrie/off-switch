	keywords = {epidemiology, {SARS}-{CoV}-2, computational biology, infectious diseases, microbiology},
	file = {Full Text:/Users/jamespetrie/Zotero/storage/56FV9CZL/Marc et al. - 2021 - Quantifying the relationship between SARS-CoV-2 vi.pdf:application/pdf},
}

