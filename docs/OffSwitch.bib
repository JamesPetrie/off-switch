@article{engering_pathogenhostenvironment_2013,
	title = {Pathogen–host–environment interplay and disease emergence},
	volume = {2},
	issn = {null},
	url = {https://doi.org/10.1038/emi.2013.5},
	doi = {10.1038/emi.2013.5},
	abstract = {Gaining insight in likely disease emergence scenarios is critical to preventing such events from happening. Recent focus has been on emerging zoonoses and on identifying common patterns and drivers of emerging diseases. However, no overarching framework exists to integrate knowledge on all emerging infectious disease events. Here, we propose such a conceptual framework based on changes in the interplay of pathogens, hosts and environment that lead to the formation of novel disease patterns and pathogen genetic adjustment. We categorize infectious disease emergence events into three groups: (i) pathogens showing up in a novel host, ranging from spill-over, including zoonoses, to complete species jumps; (ii) mutant pathogens displaying novel traits in the same host, including an increase in virulence, antimicrobial resistance and host immune escape; and (iii) disease complexes emerging in a new geographic area, either through range expansion or through long distance jumps. Each of these categories is characterized by a typical set of drivers of emergence, matching pathogen trait profiles, disease ecology and transmission dynamics. Our framework may assist in disentangling and structuring the rapidly growing amount of available information on infectious diseases. Moreover, it may contribute to a better understanding of how human action changes disease landscapes globally.Emerging Microbes \& Infections (2013) 2, e5; doi:10.1038/emi.2013.5},
	pages = {1--7},
	number = {1},
	journaltitle = {Emerging Microbes \& Infections},
	author = {Engering, Anneke and Hogerwerf, Lenny and Slingenbergh, Jan},
	urldate = {2023-08-16},
	date = {2013-01-01},
	pmid = {26038452},
	note = {Publisher: Taylor \& Francis
\_eprint: https://doi.org/10.1038/emi.2013.5},
	keywords = {drivers, geographic invasion, species jumps, virulence, zoonoses},
	file = {Full Text PDF:/Users/jamespetrie/Zotero/storage/Q5ELK3IR/Engering et al. - 2013 - Pathogen–host–environment interplay and disease em.pdf:application/pdf},
}

