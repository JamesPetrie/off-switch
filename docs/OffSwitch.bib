@article{shiaelis_virus_2023,
	title = {Virus Detection and Identification in Minutes Using Single-Particle Imaging and Deep Learning},
	volume = {17},
	issn = {1936-0851},
	url = {https://doi.org/10.1021/acsnano.2c10159},
	doi = {10.1021/acsnano.2c10159},
	abstract = {The increasing frequency and magnitude of viral outbreaks in recent decades, epitomized by the {COVID}-19 pandemic, has resulted in an urgent need for rapid and sensitive diagnostic methods. Here, we present a methodology for virus detection and identification that uses a convolutional neural network to distinguish between microscopy images of fluorescently labeled intact particles of different viruses. Our assay achieves labeling, imaging, and virus identification in less than 5 min and does not require any lysis, purification, or amplification steps. The trained neural network was able to differentiate {SARS}-{CoV}-2 from negative clinical samples, as well as from other common respiratory pathogens such as influenza and seasonal human coronaviruses. We were also able to differentiate closely related strains of influenza, as well as {SARS}-{CoV}-2 variants. Additional and novel pathogens can easily be incorporated into the test through software updates, offering the potential to rapidly utilize the technology in future infectious disease outbreaks or pandemics. Single-particle imaging combined with deep learning therefore offers a promising alternative to traditional viral diagnostic and genomic sequencing methods and has the potential for significant impact.},
	pages = {697--710},
	number = {1},
	journaltitle = {{ACS} Nano},
	shortjournal = {{ACS} Nano},
	author = {Shiaelis, Nicolas and Tometzki, Alexander and Peto, Leon and {McMahon}, Andrew and Hepp, Christof and Bickerton, Erica and Favard, Cyril and Muriaux, Delphine and Andersson, Monique and Oakley, Sarah and Vaughan, Ali and Matthews, Philippa C. and Stoesser, Nicole and Crook, Derrick W. and Kapanidis, Achillefs N. and Robb, Nicole C.},
	urldate = {2023-08-10},
	date = {2023-01-10},
	note = {Publisher: American Chemical Society},
	file = {ACS Full Text Snapshot:/Users/jamespetrie/Zotero/storage/37VD6QZW/acsnano.html:text/html;Full Text:/Users/jamespetrie/Zotero/storage/AJ3QNWHN/Shiaelis et al. - 2023 - Virus Detection and Identification in Minutes Usin.pdf:application/pdf},
}

