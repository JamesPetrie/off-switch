	langid = {english},
	keywords = {Infectious diseases, {COVID}-19, Infection control, Public policy},
	file = {Full Text PDF:/Users/jamespetrie/Zotero/storage/W5N29MB8/Grout et al. - 2021 - Failures of quarantine systems for preventing COVI.pdf:application/pdf;Snapshot:/Users/jamespetrie/Zotero/storage/ZESFLE26/mja2.html:text/html},
