	keywords = {censoring, emerging infectious diseases, importation, migration, mortality, travel},
	file = {Full Text PDF:/Users/jamespetrie/Zotero/storage/MAI4SN76/Jung et al. - 2020 - Real-Time Estimation of the Risk of Death from Nov.pdf:application/pdf},
