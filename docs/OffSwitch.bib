	note = {Publisher: American Association for the Advancement of Science},
	file = {Full Text PDF:/Users/jamespetrie/Zotero/storage/SAA67E4M/Brauner et al. - 2021 - Inferring the effectiveness of government interven.pdf:application/pdf},
}

@article{gu_rapid_2021,
