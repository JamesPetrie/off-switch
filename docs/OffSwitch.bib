@article{lewis_bedside_1979,
	title = {Bedside measurement of lung water},
	volume = {27},
	issn = {0022-4804},
	url = {https://www.sciencedirect.com/science/article/pii/0022480479901380},
	doi = {10.1016/0022-4804(79)90138-0},
	abstract = {Extravascular lung water ({EVLW}) has been measured sequentially in 12 patients by the thermal-green dye double-indicator dilution technique. {EVLW} referenced to body weight has ranged from 3.3 to 17.2 ml/kg, with normals averaging 5.7 ml/kg. The coefficient of variation of multiple readings at the same time is 8\%, so reproducibility is excellent. The method shows good correlation with other clinical parameters, including radiographic infiltrates, the {PaO}2F1O2 ratio, {PA} wedge pressure, and pulmonary compliance. Postmortem estimation of lung water in two patients was in good agreement with premortem {EVLW} measurement. The method requires a femoral artery catheter and central venous or pulmonary artery catheter, which are usually present in critically ill patients. Use of a bedside microprocessor computer allows rapid calculation of {EVLW} and cardiac output, making the results immediately available. The technique appears to be a useful and accurate clinical tool in assessing pulmonary edema of cardiogenic or noncardiogenic origin and expanded clinical use is anticipated.},
	pages = {250--261},
	number = {4},
	journaltitle = {Journal of Surgical Research},
	shortjournal = {Journal of Surgical Research},
