@online{noauthor_security_nodate,
	title = {Security Engineering: A Guide to Building Dependable Distributed Systems, 3rd Edition {\textbar} Wiley},
	url = {https://www.wiley.com/en-us/Security+Engineering%3A+A+Guide+to+Building+Dependable+Distributed+Systems%2C+3rd+Edition-p-9781119642817},
	shorttitle = {Security Engineering},
	abstract = {{\textless}p{\textgreater}\textbf{Now that there's software in everything, how can you make anything secure? Understand how to engineer dependable systems with this newly updated classic}{\textless}/p{\textgreater} {\textless}p{\textgreater}In \textit{Security Engineering: A Guide to Building Dependable Distributed Systems,} Third Edition Cambridge University professor Ross Anderson updates his classic textbook and teaches readers how to design, implement, and test systems to withstand both error and attack.{\textless}/p{\textgreater} {\textless}p{\textgreater}This book became a best-seller in 2001 and helped establish the discipline of security engineering. By the second edition in 2008, underground dark markets had let the bad guys specialize and scale up; attacks were increasingly on users rather than on technology. The book repeated its success by showing how security engineers can focus on usability.{\textless}/p{\textgreater} {\textless}p{\textgreater}Now the third edition brings it up to date for 2020. As people now go online from phones more than laptops, most servers are in the cloud, online advertising drives the Internet and social networks have taken over much human interaction, many patterns of crime and abuse are the same, but the methods have evolved. Ross Anderson explores what security engineering means in 2020, including:{\textless}/p{\textgreater} {\textless}ul{\textgreater} {\textless}li{\textgreater}How the basic elements of cryptography, protocols, and access control translate to the new world of phones, cloud services, social media and the Internet of Things{\textless}/li{\textgreater} {\textless}li{\textgreater}Who the attackers are \&ndash; from nation states and business competitors through criminal gangs to stalkers and playground bullies{\textless}/li{\textgreater} {\textless}li{\textgreater}What they do \&ndash; from phishing and carding through {SIM} swapping and software exploits to {DDoS} and fake news{\textless}/li{\textgreater} {\textless}li{\textgreater}Security psychology, from privacy through ease-of-use to deception{\textless}/li{\textgreater} {\textless}li{\textgreater}The economics of security and dependability \&ndash; why companies build vulnerable systems and governments look the other way{\textless}/li{\textgreater} {\textless}li{\textgreater}How dozens of industries went online \&ndash; well or badly{\textless}/li{\textgreater} {\textless}li{\textgreater}How to manage security and safety engineering in a world of agile development \&ndash; from reliability engineering to {DevSecOps}{\textless}/li{\textgreater} {\textless}/ul{\textgreater} {\textless}p{\textgreater}The third edition of \textit{Security Engineering} ends with a grand challenge: sustainable security. As we build ever more software and connectivity into safety-critical durable goods like cars and medical devices, how do we design systems we can maintain and defend for decades? Or will everything in the world need monthly software upgrades, and become unsafe once they stop?{\textless}/p{\textgreater}},
	titleaddon = {Wiley.com},
	urldate = {2025-04-12},
	langid = {english},
	file = {Snapshot:/Users/jamespetrie/Zotero/storage/QWLW37XB/Security+Engineering+A+Guide+to+Building+Dependable+Distributed+Systems,+3rd+Edition-p-97811196.html:text/html},
}

@article{obermaier_past_2018-1,
	title = {The Past, Present, and Future of Physical Security Enclosures: From Battery-Backed Monitoring to {PUF}-Based Inherent Security and Beyond},
	volume = {2},
	issn = {2509-3436},
	url = {https://doi.org/10.1007/s41635-018-0045-2},
	doi = {10.1007/s41635-018-0045-2},
	shorttitle = {The Past, Present, and Future of Physical Security Enclosures},
	abstract = {Withstanding physical attacks in a hostile environment is of utmost importance for nowadays electronics. However, due to the long and costly development of integrated circuits ({ICs}), {IC}-level countermeasures are typically only included in varying degree and not in every chip of a device. Therefore, multiple-chip modules requiring higher levels of security are additionally protected against tampering by a physical security enclosure, e.g., by an envelope that completely encloses the device. For decades, these physical boundaries on a device-level were monitored using battery-backed mechanisms to enable detection of an attempted physical intrusion even if the underlying system is powered off. However, the battery affects the system’s robustness, weight, prevents extended storage, and also leads to difficulties with the security mechanism while shipping the device. In this position paper, we present our assessment of various battery-backed tamper-respondent solutions and argue that while offering the intriguing benefit of instantaneous detection and response, the low-power nature of battery-backup contradicts a tamper-sensitive measurement, among other problems. We are therefore of the opinion that more effort should be spent towards enclosures that are based on tamper-evident physical unclonable functions ({PUFs}), as they are designated to provide a high level of security on the one hand and do not require a battery on the other hand. To further substantiate our argument, we summarize the work in this domain to also facilitate future research.},
	pages = {289--296},
	number = {4},
	journaltitle = {Journal of Hardware and Systems Security},
	shortjournal = {J Hardw Syst Secur},
	author = {Obermaier, Johannes and Immler, Vincent},
	urldate = {2025-04-12},
	date = {2018-12-01},
	langid = {english},
	keywords = {Anti-tamper, {FIPS} 140-2, Higher-order alphabet physical unclonable function ({HOA} {PUF}), {HSM}, Physical security enclosure, Reverse engineering, Tamper-resistance},
}

